# Resend (recommended for order & transactional emails)
# Get API key: https://resend.com/api-keys
# Verify your domain in Resend → Domains, then use an address on that domain:
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=poruchki@modabox.eu
RESEND_FROM_NAME=ModaBox
# Where new-order notifications go (comma-separated for multiple recipients)
ADMIN_EMAIL=you@yourdomain.com,partner@yourdomain.com
# Shown on site footer / reply-to in outgoing emails
CONTACT_EMAIL=poruchki@modabox.eu

# Inbound email forwarding (when someone emails CONTACT_EMAIL)
# 1. Resend → Domains → modabox.eu → enable Receiving (add MX records)
# 2. Resend → Webhooks → Add → https://yourdomain.com/api/webhooks/resend/inbound
#    Event: email.received — copy signing secret below
RESEND_WEBHOOK_SECRET=whsec_CKb3fFw3UkchcESUEyRg1lCo38Jk4bco
# Optional: only forward mail sent to this address (defaults to CONTACT_EMAIL)
RESEND_INBOUND_ADDRESS=poruchki@modabox.eu

# Legacy Gmail fallback (used only if RESEND_API_KEY is not set)
EMAIL_USER=
EMAIL_PASS=

# Supabase, site URL, etc. — keep your existing values below
