# Resend (recommended for order & transactional emails)
# Get API key: https://resend.com/api-keys
# Verify your domain in Resend → Domains, then use an address on that domain:
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=orders@yourdomain.com
RESEND_FROM_NAME=Your Store Name
# Where new-order notifications go (optional; defaults to RESEND_FROM_EMAIL)
ADMIN_EMAIL=you@yourdomain.com
# Shown in email footers / reply-to (optional)
CONTACT_EMAIL=contact@yourdomain.com

# Legacy Gmail fallback (used only if RESEND_API_KEY is not set)
EMAIL_USER=
EMAIL_PASS=

# Supabase, site URL, etc. — keep your existing values below
